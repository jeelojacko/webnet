{
  "name": "webnet-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node scripts/runVitest.mjs",
    "test:run": "node scripts/runVitest.mjs run",
    "test:cov": "node scripts/runVitest.mjs run --coverage",
    "parity:industry-reference": "node scripts/runVitest.mjs run tests/computational_parity_harness.test.ts",
    "adjust:cli": "tsx src/cli.ts",
    "corpus:legacy": "tsx src/legacyCorpusHarness.ts",
    "corpus:legacy:ci": "tsx src/legacyCorpusHarness.ts --ci",
    "corpus:legacy:baseline": "tsx src/legacyCorpusHarness.ts --write-baseline tests/fixtures/legacy_compatibility_corpus_phase1_baseline.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^0.554.0",
    "proj4": "^2.20.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "overrides": {
    "flatted": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
